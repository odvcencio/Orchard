# Core server
ORCHARD_HOST=0.0.0.0
ORCHARD_PORT=3000

# Database
ORCHARD_DB_DRIVER=postgres
ORCHARD_DB_DSN=postgres://orchard:orchard@postgres:5432/orchard?sslmode=disable

# Storage
ORCHARD_STORAGE_PATH=/data/repos

# Auth
# Must be >=16 chars and not "change-me-in-production".
ORCHARD_JWT_SECRET=dev-jwt-secret-change-this
# Orchard auth is passwordless (magic link, passkey, SSH).
# Require users to verify email via magic link before write actions (repo create/fork, protocol push).
# ORCHARD_REQUIRE_VERIFIED_EMAIL=true
# Require users to register at least one passkey before write actions.
# ORCHARD_REQUIRE_PASSKEY_ENROLLMENT=true
# Enable organization APIs and UI surfaces (disabled by default).
# ORCHARD_ENABLE_ORGANIZATIONS=false
# Optional signing secret for minting short-lived first-key SSH bootstrap tokens.
# Mint endpoint (auth required): POST /api/v1/auth/ssh/bootstrap/token
# Bootstrap endpoint: POST /api/v1/auth/ssh/bootstrap
# ORCHARD_BOOTSTRAP_SSH_TOKEN=replace-with-random-secret

# WebAuthn (optional; required for passkeys in non-local setups)
# ORCHARD_WEBAUTHN_ORIGIN=http://localhost:3001
# ORCHARD_WEBAUTHN_RPID=localhost
